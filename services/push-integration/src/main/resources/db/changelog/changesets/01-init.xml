<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog/1.9"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog/1.9
         http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-1.9.xsd">
    <changeSet author="haja" id="01-init">
        <createTable tableName="relay_connection">
            <column name="token" type="varchar">
                <constraints
                    nullable="false"
                    primaryKey="true" />
            </column>
            <column name="relay_url" type="varchar">
                <constraints nullable="false" />
            </column>
            <column name="relay_cert" type="blob">
                <constraints nullable="false" />
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
